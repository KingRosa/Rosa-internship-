{
  "extends": [
    "development"
  ],
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_ff <= 150",
    "not firefox <= 151",
    "not safari <= 26.5",
    "not samsung <= 29"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "-ms-touch-action"
        ]
      }
    ]
  }
}